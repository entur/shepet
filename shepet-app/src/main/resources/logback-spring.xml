<configuration>
    <!-- Pretty console logging for local development (via 'local' profile from pom.xml) -->
    <springProfile name="local">
        <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
        <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

        <logger name="org.entur.shepet" level="DEBUG"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- JSON structured logging for CI/CD and production -->
    <springProfile name="!local">
        <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <pattern>
                        <pattern>
                            {
                                "serviceContext": {
                                    "service": "shepet-app"
                                },
                                "eventTime": "%date{\"yyyy-MM-dd'T'HH:mm:ss.SSS'000000Z'\", \"UTC\"}",
                                "thread": "%thread",
                                "message": "%message\n%ex{full}",
                                "severity": "%level",
                                "reportLocation": {
                                    "filePath": "%logger",
                                    "lineNumber": "%line",
                                    "functionName": "%method"
                                },
                                "operation": {
                                    "id": "%X{importCorrelationId}"
                                }
                            }
                        </pattern>
                    </pattern>
                </providers>
            </encoder>
        </appender>

        <logger name="com" level="INFO"/>
        <logger name="no" level="INFO"/>
        <logger name="org" level="INFO"/>
        <logger name="org.apache" level="INFO"/>

        <root level="INFO">
            <appender-ref ref="console"/>
        </root>
    </springProfile>
</configuration>
